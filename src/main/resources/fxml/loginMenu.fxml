<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="view.LoginMenuController"
            prefHeight="400.0" prefWidth="600.0">
        <center>
            <VBox alignment="CENTER" spacing="5">
                <Label text="welcome!"/>
                <TextField promptText="username" maxWidth="300" fx:id="username"/>
                <PasswordField promptText="password" maxWidth="300" fx:id="password"/>
                <HBox alignment="CENTER" spacing="10">
                    <Button text="login" onMouseClicked="#login"/>
                    <Button text="Create an account" onMouseClicked="#createAccount"/>
                </HBox>
                <Button text="Play as a guest" onMouseClicked="#playAsGuest"/>
            </VBox>
        </center>

</BorderPane>
