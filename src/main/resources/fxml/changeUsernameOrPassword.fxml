<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="view.ProfileMenu"
            prefHeight="400.0" prefWidth="600.0">

    <center>
        <VBox alignment="CENTER" spacing="10">
            <Label text="Change your account"/>
            <TextField promptText="newUsername" maxWidth="300" fx:id="username"/>
            <PasswordField promptText="newPassword" maxWidth="300" fx:id="password"/>
            <Button text="Change" onMouseClicked="#changeFunction"/>
        </VBox>
    </center>
</BorderPane>
