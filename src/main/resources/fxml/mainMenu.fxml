<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="view.MainMenuController"
            prefHeight="400.0" prefWidth="600.0">
    <center>
        <VBox alignment="CENTER" spacing="10">
            <Label text="Main Menu" style="-fx-font-size: 20px"/>
            <Button text="New game" onMouseClicked="#newGame"/>
            <Button text="continue game"/>
            <Button text="Profile menu" onMouseClicked="#profileMenu"/>
            <Button text="ScoreBord" onMouseClicked="#scoreBord"/>
            <Button text="Setting" onMouseClicked="#setting"/>
            <Button text="Exit" onMouseClicked="#exit"/>
        </VBox>

    </center>

</BorderPane>





